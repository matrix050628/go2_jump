+    std::array<double, 4> ComputeFootContactForceMagnitudes() const
+    {
+        std::array<double, 4> foot_forces{{0.0, 0.0, 0.0, 0.0}};
+        if (!mj_model_ || !mj_data_ || mj_data_->ncon <= 0) {
+            return foot_forces;
+        }
+
+        for (int contact_index = 0; contact_index < mj_data_->ncon; ++contact_index) {
+            const auto& contact = mj_data_->contact[contact_index];
+            double contact_wrench[6]{};
+            mj_contactForce(mj_model_, mj_data_, contact_index, contact_wrench);
+            const double contact_force_magnitude = std::sqrt(
+                contact_wrench[0] * contact_wrench[0] +
+                contact_wrench[1] * contact_wrench[1] +
+                contact_wrench[2] * contact_wrench[2]);
+
+            if (contact_force_magnitude <= 0.0) {
+                continue;
+            }
+
+            for (std::size_t foot_index = 0; foot_index < foot_geom_ids_.size(); ++foot_index) {
+                const int foot_geom_id = foot_geom_ids_[foot_index];
+                if (foot_geom_id < 0) {
+                    continue;
+                }
+                if (contact.geom1 == foot_geom_id || contact.geom2 == foot_geom_id) {
+                    foot_forces[foot_index] += contact_force_magnitude;
+                }
+            }
+        }
+
+        return foot_forces;
+    }

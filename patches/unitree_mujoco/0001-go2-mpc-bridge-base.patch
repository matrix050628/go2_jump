+template <typename MsgType>
+class ChannelSubscriptionBuffer
+{
+public:
+    explicit ChannelSubscriptionBuffer(const std::string& topic)
+        : ChannelSubscriptionBuffer(std::vector<std::string>{topic})
+    {
+    }
+
+    explicit ChannelSubscriptionBuffer(const std::vector<std::string>& topics)
+    {
+        for (const auto& topic : topics) {
+            auto subscriber = std::make_shared<unitree::robot::ChannelSubscriber<MsgType>>(topic);
+            subscriber->InitChannel(
+                [this](const void* message) {
+                    std::lock_guard<std::mutex> lock(mutex_);
+                    msg_ = *static_cast<const MsgType*>(message);
+                },
+                1);
+            subscribers_.push_back(subscriber);
+        }
+    }
+
+    MsgType msg_{};
+    std::mutex mutex_;
+
+private:
+    std::vector<unitree::robot::ChannelSubscriberPtr<MsgType>> subscribers_;
+};
+
+template <typename MsgType>
+class ChannelPublisherBuffer
+{
+public:
+    explicit ChannelPublisherBuffer(const std::string& topic)
+        : ChannelPublisherBuffer(std::vector<std::string>{topic})
+    {
+    }
+
+    explicit ChannelPublisherBuffer(const std::vector<std::string>& topics)
+    {
+        for (const auto& topic : topics) {
+            auto publisher = std::make_shared<unitree::robot::ChannelPublisher<MsgType>>(topic);
+            publisher->InitChannel();
+            publishers_.push_back(publisher);
+        }
+    }
+
+    bool trylock()
+    {
+        return mutex_.try_lock();
+    }
+
+    void publish()
+    {
+        MsgType outgoing = msg_;
+        for (const auto& publisher : publishers_) {
+            publisher->Write(outgoing, 0);
+        }
+    }
+
+    void unlockAndPublish()
+    {
+        mutex_.unlock();
+        publish();
+    }
+
+    MsgType msg_{};
+    std::mutex mutex_;
+
+protected:
+    std::vector<unitree::robot::ChannelPublisherPtr<MsgType>> publishers_;
+};

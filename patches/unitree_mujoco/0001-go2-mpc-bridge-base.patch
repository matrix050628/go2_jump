+template <typename MsgType>
+void WriteFootContactForces(MsgType&, const std::array<double, 4>&)
+{
+}
+
+inline void WriteFootContactForces(
+    unitree_go::msg::dds_::LowState_& msg,
+    const std::array<double, 4>& foot_contact_forces)
+{
+    for (std::size_t foot_index = 0; foot_index < foot_contact_forces.size(); ++foot_index) {
+        const auto quantized_force = static_cast<int16_t>(std::round(
+            std::clamp(foot_contact_forces[foot_index] * 10.0, 0.0, 32767.0)));
+        msg.foot_force()[foot_index] = quantized_force;
+        msg.foot_force_est()[foot_index] = quantized_force;
+    }
+}

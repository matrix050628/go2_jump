+class Go2LowStatePublisher : public ChannelPublisherBuffer<unitree_go::msg::dds_::LowState_>
+{
+public:
+    using MsgType = unitree_go::msg::dds_::LowState_;
+    using ChannelPublisherBuffer<MsgType>::ChannelPublisherBuffer;
+
+    std::shared_ptr<unitree::common::UnitreeJoystick> joystick = nullptr;
+
+    void unlockAndPublish()
+    {
+        if (joystick) {
+            const auto key = joystick->combine();
+            std::memcpy(this->msg_.wireless_remote().data(), key.buff, sizeof(key.buff));
+        }
+        this->msg_.crc() = crc32_core(reinterpret_cast<uint32_t*>(&this->msg_), (sizeof(MsgType) >> 2) - 1);
+        ChannelPublisherBuffer<MsgType>::unlockAndPublish();
+    }
+};

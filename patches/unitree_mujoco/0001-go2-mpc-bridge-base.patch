+inline uint32_t crc32_core(uint32_t* ptr, uint32_t len)
+{
+    uint32_t xbit = 0;
+    uint32_t data = 0;
+    uint32_t crc32 = 0xFFFFFFFF;
+    const uint32_t polynomial = 0x04c11db7;
+
+    for (uint32_t i = 0; i < len; i++)
+    {
+        xbit = 1U << 31;
+        data = ptr[i];
+        for (uint32_t bits = 0; bits < 32; bits++)
+        {
+            if (crc32 & 0x80000000U)
+            {
+                crc32 <<= 1;
+                crc32 ^= polynomial;
+            }
+            else
+            {
+                crc32 <<= 1;
+            }
+
+            if (data & xbit)
+            {
+                crc32 ^= polynomial;
+            }
+            xbit >>= 1;
+        }
+    }
+
+    return crc32;
+}
